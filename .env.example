# ---- Issuer（發行方）----
# 訪客通行證樣板；未設定時回退為員工卡樣板（VC_SERNUM / VC_UID）
VISITOR_VC_SERNUM=YOUR_VISITOR_VC_SERNUM
VISITOR_VC_UID=YOUR_VISITOR_VC_UID
# 員工卡樣板（作為 fallback，或未來直接發員工卡用）
VC_SERNUM=YOUR_VC_SERNUM
VC_UID=YOUR_VC_UID
ISSUER_ACCESS_TOKEN=YOUR_ISSUER_ACCESS_TOKEN

# ---- Verifier（驗證方 / OIDVP）----
# 驗證「持有有效員工卡」的參考碼；未設定時回退為 VERIFIER_SPORT_REF
VERIFIER_ACCESS_REF=YOUR_VERIFIER_REF_FOR_ACCESS
VERIFIER_SPORT_REF=YOUR_VERIFIER_REF_FOR_SPORT_SUBSIDY
VERIFIER_ACCESS_TOKEN=YOUR_VERIFIER_ACCESS_TOKEN

# ---- 應用設定 ----
VISITOR_TTL_HOURS=4
PORT=8080
